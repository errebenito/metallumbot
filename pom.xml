<project
	xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<groupId>com.github.errebenito</groupId>
	<artifactId>metallumbot</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>MetallumBot</name>
	<description>Unofficial Metal Archives Telegram Bot</description>
	<properties>
		<maven.compiler.source>24</maven.compiler.source>
		<maven.compiler.target>24</maven.compiler.target>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<sonar.organization>errebenito</sonar.organization>
		<sonar.host.url>https://sonarcloud.io</sonar.host.url>
		<telegrambots.version>9.3.0</telegrambots.version>
	</properties>
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>org.apache.logging.log4j</groupId>
				<artifactId>log4j-bom</artifactId>
				<version>2.25.3</version>
				<scope>import</scope>
				<type>pom</type>
			</dependency>
			<dependency>
				<groupId>org.junit</groupId>
				<artifactId>junit-bom</artifactId>
				<version>6.0.2</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
			<dependency>
				<groupId>org.mockito</groupId>
    			<artifactId>mockito-bom</artifactId>
    			<version>5.21.0</version>
    			<type>pom</type>
    			<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>
	<dependencies>
		<dependency>
			<groupId>org.telegram</groupId>
			<artifactId>telegrambots-longpolling</artifactId>
			<version>${telegrambots.version}</version>
		</dependency>
		<dependency>
			<groupId>org.telegram</groupId>
			<artifactId>telegrambots-client</artifactId>
			<version>${telegrambots.version}</version>
		</dependency>
		<dependency>
			<groupId>org.apache.logging.log4j</groupId>
			<artifactId>log4j-api</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.logging.log4j</groupId>
			<artifactId>log4j-core</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.logging.log4j</groupId>
			<artifactId>log4j-slf4j2-impl</artifactId>
		</dependency>
		<dependency>
 			<groupId>org.jsoup</groupId>
  			<artifactId>jsoup</artifactId>
  			<version>1.22.1</version>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-engine</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-api</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
    		<artifactId>junit-jupiter-params</artifactId>
    		<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>com.squareup.okhttp3</groupId>
  		  	<artifactId>mockwebserver</artifactId>
  			<version>4.12.0</version>
  			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.mockito</groupId>
			<artifactId>mockito-core</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.mockito</groupId>
			<artifactId>mockito-junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>
	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-dependency-plugin</artifactId>
				<executions>
					<execution>
						<goals>
							<goal>properties</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<version>3.5.4</version>
				<configuration>
					<argLine>@{argLine} -javaagent:${org.mockito:mockito-core:jar}</argLine>
					<includes>
						<include>com.github.errebenito.metallumbot.ApplicationTest</include>
						<include>com.github.errebenito.metallumbot.bot.CommandProcessorTest</include>
						<include>com.github.errebenito.metallumbot.bot.MetallumBotTest</include>
						<include>com.github.errebenito.metallumbot.randomband.MetalArchivesRandomBandProviderTest</include>
						<include>com.github.errebenito.metallumbot.randomband.RandomBandUseCaseTest</include>
						<include>com.github.errebenito.metallumbot.upcomingalbum.CurlUpcomingAlbumProviderTest</include>
						<include>com.github.errebenito.metallumbot.upcomingalbum.HtmlUpcomingAlbumProviderTest</include>
						<include>com.github.errebenito.metallumbot.upcomingalbum.RandomUpcomingAlbumUseCaseTest</include>
						<include>com.github.errebenito.metallumbot.upcomingalbum.JsoupHtmlFetcherTest</include>
						<include>com.github.errebenito.metallumbot.upcomingalbum.SystemCurlExecutorTest</include>
					</includes>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-shade-plugin</artifactId>
				<version>3.6.1</version>
				<executions>
					<execution>
						<phase>package</phase>
						<goals>
							<goal>shade</goal>
						</goals>
						<configuration>
							<createDependencyReducedPom>false</createDependencyReducedPom>
							<filters>
								<filter>
									<artifact>*:*</artifact>
									<excludes>
										<exclude>META-INF/*.SF</exclude>
										<exclude>META-INF/*.DSA</exclude>
										<exclude>META-INF/*.RSA</exclude>
										<exclude>META-INF/LICENSE</exclude>
										<exclude>META-INF/LICENSE.txt</exclude>
										<exclude>META-INF/NOTICE</exclude>
										<exclude>META-INF/NOTICE.txt</exclude>
										<exclude>META-INF/DEPENDENCIES</exclude>
										<exclude>META-INF/MANIFEST.MF</exclude>
										<exclude>META-INF/okio.kotlin_module</exclude>
										<exclude>META-INF/versions/**/module-info.class</exclude>
										<exclude>module-info.class</exclude>
									</excludes>
								</filter>
							</filters>
							<transformers>
								<transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
									<mainClass>com.github.errebenito.metallumbot.Main</mainClass>
								</transformer>
							</transformers>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.jacoco</groupId>
				<artifactId>jacoco-maven-plugin</artifactId>
				<version>0.8.14</version>
				<configuration>
					<excludes>
						<exclude>**/Main.class</exclude>
					</excludes>
				</configuration>
				<executions>
					<execution>
						<id>prepare-agent</id>
						<goals>
							<goal>prepare-agent</goal>
						</goals>
					</execution>
					<execution>
						<id>report</id>
						<phase>test</phase>
						<goals>
							<goal>report</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>
	<profiles>
		<profile>
			<id>mutation</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.pitest</groupId>
						<artifactId>pitest-maven</artifactId>
						<version>1.22.1</version>
						<executions>
							<execution>
								<id>pit-report</id>
								<phase>test-compile</phase>
								<goals>
									<goal>mutationCoverage</goal>
								</goals>
							</execution>
						</executions>
						<dependencies>
							<dependency>
								<groupId>org.pitest</groupId>
								<artifactId>pitest-junit5-plugin</artifactId>
								<version>1.2.3</version>
							</dependency>
						</dependencies>
						<configuration>
							<excludedClasses>
        						<param>com.github.errebenito.metallumbot.Main</param>
    						</excludedClasses>
							<targetClasses>
								<param>com.github.errebenito.metallumbot.Application</param>
								<param>com.github.errebenito.metallumbot.bot.CommandProcessor</param>
								<param>com.github.errebenito.metallumbot.bot.MetallumBot</param>
								<param>com.github.errebenito.metallumbot.bot.MetallumBotMessageSender</param>
								<param>com.github.errebenito.metallumbot.model.Command</param>
								<param>com.github.errebenito.metallumbot.randomband.MetalArchivesRandomBandProvider</param>
								<param>com.github.errebenito.metallumbot.randomband.RandomBandUseCase</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.CurlUpcomingAlbumProvider</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.HtmlUpcomingAlbumProvider</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.RandomUpcomingAlbumUseCase</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.JsoupHtmlFetcher</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.SystemCurlExecutor</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.CurlProcessStarter</param>
							</targetClasses>
							<targetTests>
								<param>com.github.errebenito.metallumbot.ApplicationTest</param>
								<param>com.github.errebenito.metallumbot.bot.CommandProcessorTest</param>
								<param>com.github.errebenito.metallumbot.bot.MetallumBotTest</param>
								<param>com.github.errebenito.metallumbot.randomband.MetalArchivesRandomBandProviderTest</param>
								<param>com.github.errebenito.metallumbot.randomband.RandomBandUseCaseTest</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.CurlUpcomingAlbumProviderTest</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.HtmlUpcomingAlbumProviderTest</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.RandomUpcomingAlbumUseCaseTest</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.JsoupHtmlFetcherTest</param>
								<param>com.github.errebenito.metallumbot.upcomingalbum.SystemCurlExecutorTest</param>
							</targetTests>
							<outputFormats>
								<outputFormat>xml</outputFormat>
								<outputFormat>html</outputFormat>
							</outputFormats>
							<timestampedReports>false</timestampedReports>
							<failWhenNoMutations>false</failWhenNoMutations>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
